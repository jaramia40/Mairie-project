---
import Layout from '../layouts/Layout.astro';
import ActualiteCard from '../components/ui/ActualiteCard.astro';
import QuickLinks from '../components/ui/QuickLinks.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
type Actu = CollectionEntry<'actualites'>;

const allActualites = await getCollection('actualites');
const latest = allActualites
  .filter((a: Actu) => a.data.publie)
  .sort((a: Actu, b: Actu) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout
  title="Accueil — Commune d'Artassenx"
  description="Site officiel de la commune d'Artassenx (Landes, 40090). Actualités, services municipaux, associations et vie locale."
  canonical="https://artassenx.fr/"
>
  <!-- ===== HERO : BANNIÈRE STICKY ===== -->
  <!--
    La section est sticky (z-0) : elle reste collée sous le header pendant que
    le bloc .page-content (z-1, fond blanc) glisse par-dessus au scroll.
  -->
  <section
    aria-label="Présentation de la commune"
    style="position: sticky; top: 64px; z-index: 0;"
  >
    <!-- Seule l'image est sticky — ratio 16/7, pleine largeur, sans déformation -->
    <img
      src="/images/banniere.jpg"
      alt="La mairie d'Artassenx et le blason de la commune"
      class="w-full block"
      style="aspect-ratio: 16/7; min-height: 220px; object-fit: cover; object-position: top center;"
      loading="eager"
      fetchpriority="high"
      width="1536"
      height="1024"
    />
  </section>

  <!-- ===== CONTENU QUI GLISSE PAR-DESSUS LA BANNIÈRE ===== -->
  <div style="position: relative; z-index: 1; background: white;">

    <!-- Bandeau CTA navy : premier élément à monter sur la bannière -->
    <div style="background: linear-gradient(90deg, #1A2D6B 0%, #111E4A 100%);">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <p class="text-xs font-light tracking-widest uppercase text-gold mb-1 opacity-90">
            285 habitants · Département des Landes · 40090
          </p>
          <p class="text-sm font-light text-white/75 leading-relaxed max-w-lg">
            Retrouvez toutes les informations municipales, l'agenda des événements et les services de votre commune.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 flex-shrink-0">
          <a
            href="/actualites"
            class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-white text-sm font-medium px-5 py-2.5 rounded transition-colors"
            aria-label="Voir toutes les actualités de la commune"
          >
            Nos actualités
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white text-sm font-normal px-5 py-2.5 rounded border border-white/20 transition-colors"
            aria-label="Contacter la mairie d'Artassenx"
          >
            Contacter la mairie
          </a>
        </div>
      </div>
    </div>

  <!-- RACCOURCIS RAPIDES -->
  <section
    class="bg-white border-b border-gray-100"
    aria-labelledby="quicklinks-heading"
  >
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <h2 id="quicklinks-heading" class="sr-only">Accès rapides</h2>
      <QuickLinks locale="fr" />
    </div>
  </section>

  <!-- ===== DERNIÈRES ACTUALITÉS ===== -->
  <section
    class="max-w-6xl mx-auto px-4 sm:px-6 py-14"
    aria-labelledby="news-heading"
  >
    <div class="flex items-center justify-between mb-8" data-animate>
      <div>
        <h2 id="news-heading" class="text-2xl font-semibold text-navy">
          Dernières actualités
        </h2>
        <p class="text-sm font-light mt-1" style="color: #6B6B68;">
          Informations et événements de votre commune
        </p>
      </div>
      <a
        href="/actualites"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-gold hover:text-gold-light transition-colors"
        aria-label="Voir toutes les actualités"
      >
        Tout voir
        <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    {latest.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latest.map((article: CollectionEntry<'actualites'>) => (
          <ActualiteCard
            title={article.data.title}
            date={article.data.date}
            categorie={article.data.categorie}
            extrait={article.data.extrait}
            slug={article.slug}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
          />
        ))}
      </div>
    ) : (
      <p class="text-sm font-light text-gray-500">Aucune actualité pour le moment.</p>
    )}

    <div class="mt-8 sm:hidden text-center">
      <a
        href="/actualites"
        class="inline-flex items-center gap-2 text-sm font-medium text-gold hover:text-gold-light transition-colors"
        aria-label="Voir toutes les actualités"
      >
        Voir toutes les actualités
        <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ===== INFOS PRATIQUES RAPIDES ===== -->
  <section
    class="py-12 px-4 sm:px-6"
    style="background-color: #F5F5F3;"
    aria-labelledby="infos-heading"
  >
    <div class="max-w-6xl mx-auto">
      <h2 id="infos-heading" class="text-xl font-semibold text-navy mb-6" data-animate>
        La commune en bref
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">

        <!-- Mairie -->
        <div class="bg-white rounded-card p-5 border border-gray-100" data-animate>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center flex-shrink-0">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="2" y="7" width="14" height="9" rx="1.5" stroke="#1A2D6B" stroke-width="1.3"/>
                <path d="M1 7L9 2L17 7" stroke="#1A2D6B" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="7" y="11" width="4" height="5" rx="0.5" stroke="#C47A0A" stroke-width="1.2"/>
              </svg>
            </div>
            <h3 class="text-sm font-medium text-navy">Mairie</h3>
          </div>
          <p class="text-xs font-light text-gray-600 leading-relaxed">
            Lieu-dit Artassenx<br />
            40090 Artassenx<br />
            Tél. 05 58 00 00 00
          </p>
        </div>

        <!-- Horaires -->
        <div class="bg-white rounded-card p-5 border border-gray-100" data-animate>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center flex-shrink-0">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="7" stroke="#C47A0A" stroke-width="1.3"/>
                <path d="M9 5V9L12 11" stroke="#C47A0A" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="text-sm font-medium text-navy">Horaires</h3>
          </div>
          <p class="text-xs font-light text-gray-600 leading-relaxed">
            Lundi – Vendredi<br />
            9h00 – 12h00<br />
            <a href="/vie-pratique#horaires" class="text-gold hover:underline">Horaires détaillés →</a>
          </p>
        </div>

        <!-- Population -->
        <div class="bg-white rounded-card p-5 border border-gray-100" data-animate>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-emerald-50 flex items-center justify-center flex-shrink-0">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="7" cy="6" r="3" stroke="#065F46" stroke-width="1.3"/>
                <path d="M2 16c0-3 2.2-5 5-5s5 2 5 5" stroke="#065F46" stroke-width="1.3" stroke-linecap="round"/>
                <circle cx="13" cy="7" r="2" stroke="#065F46" stroke-width="1.2"/>
                <path d="M13 12c1.5 0 3 1 3 4" stroke="#065F46" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="text-sm font-medium text-navy">Population</h3>
          </div>
          <p class="text-xs font-light text-gray-600 leading-relaxed">
            285 habitants<br />
            Arrondissement de Mont-de-Marsan<br />
            Canton de Grenade-sur-l'Adour
          </p>
        </div>

      </div>
    </div>
  </section>

  </div><!-- fin .page-content -->
</Layout>
