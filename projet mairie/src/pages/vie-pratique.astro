---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Vie pratique — Commune d'Artassenx"
  description="Informations pratiques de la commune d'Artassenx : horaires mairie, démarches administratives, services publics et contacts utiles."
  canonical="https://artassenx.fr/vie-pratique/"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">
    <!-- En-tête -->
    <header class="mb-10" data-animate>
      <nav aria-label="Fil d'Ariane" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-normal text-gray-400">
          <li><a href="/" class="hover:text-gold transition-colors">Accueil</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-gray-600">Vie pratique</li>
        </ol>
      </nav>
      <h1 class="text-3xl font-semibold text-navy mb-2">Vie pratique</h1>
      <p class="text-sm font-light max-w-xl" style="color: #6B6B68;">
        Tout ce dont vous avez besoin pour vos démarches du quotidien.
      </p>
    </header>

    <!-- Horaires mairie -->
    <section id="horaires" class="mb-10 scroll-mt-20" aria-labelledby="horaires-heading" data-animate>
      <h2 id="horaires-heading" class="text-lg font-semibold text-navy mb-4 flex items-center gap-2">
        <span class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center flex-shrink-0" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="6" stroke="#C47A0A" stroke-width="1.3"/>
            <path d="M8 4V8L11 10" stroke="#C47A0A" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        Horaires d'ouverture
      </h2>
      <div class="bg-white rounded-card border border-gray-100 overflow-hidden">
        <table class="w-full text-sm" role="table">
          <caption class="sr-only">Horaires d'ouverture de la mairie d'Artassenx</caption>
          <tbody>
            {[
              ['Lundi', '9h00 – 12h00'],
              ['Mardi', '9h00 – 12h00'],
              ['Mercredi', '9h00 – 12h00'],
              ['Jeudi', '9h00 – 12h00'],
              ['Vendredi', '9h00 – 12h00'],
              ['Samedi', 'Fermé'],
              ['Dimanche', 'Fermé'],
            ].map(([jour, heures], i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                <td class="px-5 py-3 font-medium text-navy w-36">{jour}</td>
                <td class={`px-5 py-3 font-light ${heures === 'Fermé' ? 'text-gray-400' : 'text-gray-700'}`}>
                  {heures}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs font-light text-gray-500">
        * Sauf jours fériés. Des permanences spéciales peuvent être organisées sur demande.
      </p>
    </section>

    <!-- Démarches administratives -->
    <section class="mb-10" aria-labelledby="demarches-heading" data-animate>
      <h2 id="demarches-heading" class="text-lg font-semibold text-navy mb-4 flex items-center gap-2">
        <span class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center flex-shrink-0" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <rect x="2" y="2" width="12" height="12" rx="2" stroke="#1A2D6B" stroke-width="1.3"/>
            <path d="M5 7H11M5 10H8" stroke="#1A2D6B" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
        </span>
        Démarches administratives
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          {
            titre: 'Carte d\'identité & Passeport',
            desc: 'Les demandes se font auprès d\'une mairie équipée d\'un dispositif de recueil. La plus proche est à Mont-de-Marsan.',
            lien: 'https://www.service-public.fr/particuliers/vosdroits/N358',
            label: 'Informations CNI / Passeport',
          },
          {
            titre: 'État civil',
            desc: 'Naissance, mariage, décès : les actes d\'état civil sont délivrés par la mairie du lieu de l\'événement.',
            lien: null,
            label: null,
          },
          {
            titre: 'Listes électorales',
            desc: 'Inscription sur les listes électorales possible en mairie ou sur internet. Délai : 6 semaines avant le scrutin.',
            lien: 'https://www.service-public.fr/particuliers/vosdroits/F1444',
            label: "Inscription sur les listes",
          },
          {
            titre: 'Urbanisme & Permis',
            desc: 'Déclarations de travaux, permis de construire et certificats d\'urbanisme. Le PLU est consultable en mairie.',
            lien: null,
            label: null,
          },
        ].map(({ titre, desc, lien, label }) => (
          <div class="bg-white rounded-card border border-gray-100 p-5">
            <h3 class="text-sm font-medium text-navy mb-2">{titre}</h3>
            <p class="text-xs font-light text-gray-600 leading-relaxed mb-3">{desc}</p>
            {lien && label && (
              <a
                href={lien}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${label} (nouvelle fenêtre)`}
                class="text-xs font-medium text-gold hover:text-gold-light transition-colors inline-flex items-center gap-1"
              >
                {label}
                <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M2 8L8 2M5 2H8V5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            )}
            {!lien && (
              <a
                href="/contact"
                class="text-xs font-medium text-gold hover:text-gold-light transition-colors"
                aria-label={`Contacter la mairie pour : ${titre}`}
              >
                Contacter la mairie →
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Numéros utiles -->
    <section id="urgences" class="mb-10 scroll-mt-20" aria-labelledby="urgences-heading" data-animate>
      <h2 id="urgences-heading" class="text-lg font-semibold text-navy mb-4 flex items-center gap-2">
        <span class="w-7 h-7 rounded-lg bg-red-50 flex items-center justify-center flex-shrink-0" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 2L2 14H14L8 2Z" stroke="#991B1B" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M8 6V9" stroke="#991B1B" stroke-width="1.3" stroke-linecap="round"/>
            <circle cx="8" cy="11.5" r="0.6" fill="#991B1B"/>
          </svg>
        </span>
        Numéros d'urgence
      </h2>
      <div class="bg-white rounded-card border border-gray-100 overflow-hidden">
        {[
          { label: 'SAMU', num: '15' },
          { label: 'Pompiers', num: '18' },
          { label: 'Police / Gendarmerie', num: '17' },
          { label: 'Urgences européen', num: '112' },
          { label: 'Numéro d\'urgence sourds/malentendants', num: '114' },
        ].map(({ label, num }, i) => (
          <div class={`flex items-center justify-between px-5 py-3 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
            <span class="text-sm font-light text-gray-700">{label}</span>
            <a
              href={`tel:${num}`}
              class="text-lg font-semibold text-navy hover:text-gold transition-colors"
              aria-label={`Appeler le ${label} : ${num}`}
            >
              {num}
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- Liens utiles -->
    <section data-animate aria-labelledby="liens-heading">
      <h2 id="liens-heading" class="text-lg font-semibold text-navy mb-4">Liens utiles</h2>
      <ul class="flex flex-col gap-2" role="list">
        {[
          { label: 'Service-public.fr', href: 'https://www.service-public.fr', desc: 'Démarches administratives en ligne' },
          { label: 'Département des Landes', href: 'https://www.landes.fr', desc: 'Conseil départemental des Landes' },
          { label: 'Préfecture des Landes', href: 'https://www.landes.gouv.fr', desc: 'Préfecture et sous-préfectures' },
          { label: 'Légifrance', href: 'https://www.legifrance.gouv.fr', desc: 'Droit français en ligne' },
        ].map(({ label, href, desc }) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${label} — ${desc} (nouvelle fenêtre)`}
              class="flex items-center justify-between p-4 bg-white rounded-lg border border-gray-100 hover:border-gold/30 hover:bg-amber-50/30 transition-colors group"
            >
              <div>
                <span class="text-sm font-medium text-navy group-hover:text-gold transition-colors">
                  {label}
                </span>
                <p class="text-xs font-light text-gray-500 mt-0.5">{desc}</p>
              </div>
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-gray-300 group-hover:text-gold transition-colors flex-shrink-0">
                <path d="M3 11L11 3M7 3H11V7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Layout>
