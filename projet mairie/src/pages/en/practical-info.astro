---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Practical information — Artassenx"
  description="Practical information about Artassenx: opening hours, administrative procedures, public services and useful contacts."
  canonical="https://artassenx.fr/en/practical-info/"
  locale="en"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">
    <header class="mb-10" data-animate>
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-normal text-gray-400">
          <li><a href="/en" class="hover:text-gold transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-gray-600">Practical info</li>
        </ol>
      </nav>
      <h1 class="text-3xl font-semibold text-navy mb-2">Practical information</h1>
      <p class="text-sm font-light max-w-xl" style="color: #6B6B68;">
        Everything you need for your daily life in Artassenx.
      </p>
    </header>

    <!-- Opening hours -->
    <section id="hours" class="mb-10 scroll-mt-20" aria-labelledby="hours-heading" data-animate>
      <h2 id="hours-heading" class="text-lg font-semibold text-navy mb-4">Opening hours</h2>
      <div class="bg-white rounded-card border border-gray-100 overflow-hidden">
        <table class="w-full text-sm" role="table">
          <caption class="sr-only">Artassenx town hall opening hours</caption>
          <tbody>
            {[
              ['Monday', '9:00 am – 12:00 pm'],
              ['Tuesday', '9:00 am – 12:00 pm'],
              ['Wednesday', '9:00 am – 12:00 pm'],
              ['Thursday', '9:00 am – 12:00 pm'],
              ['Friday', '9:00 am – 12:00 pm'],
              ['Saturday', 'Closed'],
              ['Sunday', 'Closed'],
            ].map(([day, hours], i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                <td class="px-5 py-3 font-medium text-navy w-36">{day}</td>
                <td class={`px-5 py-3 font-light ${hours === 'Closed' ? 'text-gray-400' : 'text-gray-700'}`}>
                  {hours}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Emergency numbers -->
    <section id="urgences" class="mb-10 scroll-mt-20" aria-labelledby="emergency-heading" data-animate>
      <h2 id="emergency-heading" class="text-lg font-semibold text-navy mb-4">Emergency numbers</h2>
      <div class="bg-white rounded-card border border-gray-100 overflow-hidden">
        {[
          ['SAMU (Medical emergency)', '15'],
          ['Fire brigade', '18'],
          ['Police / Gendarmerie', '17'],
          ['European emergency', '112'],
        ].map(([label, num], i) => (
          <div class={`flex items-center justify-between px-5 py-3 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
            <span class="text-sm font-light text-gray-700">{label}</span>
            <a href={`tel:${num}`} class="text-lg font-semibold text-navy hover:text-gold transition-colors" aria-label={`Call ${label}: ${num}`}>{num}</a>
          </div>
        ))}
      </div>
    </section>

    <!-- Useful links -->
    <section data-animate aria-labelledby="links-heading">
      <h2 id="links-heading" class="text-lg font-semibold text-navy mb-4">Useful links</h2>
      <ul class="flex flex-col gap-2" role="list">
        {[
          { label: 'Service-public.fr', href: 'https://www.service-public.fr', desc: 'French online public services' },
          { label: 'Landes Department', href: 'https://www.landes.fr', desc: 'Landes departmental council' },
          { label: 'Prefecture of Landes', href: 'https://www.landes.gouv.fr', desc: 'Prefecture and sub-prefectures' },
        ].map(({ label, href, desc }) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${label} — ${desc} (new tab)`}
              class="flex items-center justify-between p-4 bg-white rounded-lg border border-gray-100 hover:border-gold/30 hover:bg-amber-50/30 transition-colors group"
            >
              <div>
                <span class="text-sm font-medium text-navy group-hover:text-gold transition-colors">{label}</span>
                <p class="text-xs font-light text-gray-500 mt-0.5">{desc}</p>
              </div>
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-gray-300 group-hover:text-gold transition-colors">
                <path d="M3 11L11 3M7 3H11V7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Layout>
