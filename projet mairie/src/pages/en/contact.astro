---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Contact — Artassenx"
  description="Contact Artassenx town hall: online form, phone, address and opening hours."
  canonical="https://artassenx.fr/en/contact/"
  locale="en"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">
    <header class="mb-10" data-animate>
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-normal text-gray-400">
          <li><a href="/en" class="hover:text-gold transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-gray-600">Contact</li>
        </ol>
      </nav>
      <h1 class="text-3xl font-semibold text-navy mb-2">Contact us</h1>
      <p class="text-sm font-light max-w-xl" style="color: #6B6B68;">
        We reply to emails within 3 working days. For urgent matters, please call us.
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <!-- Form -->
      <div class="lg:col-span-3" data-animate>
        <div id="form-success" role="alert" aria-live="polite" class="hidden mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-lg text-sm font-normal text-emerald-800">
          Your message has been sent. We will get back to you as soon as possible.
        </div>

        <form
          id="contact-form-en"
          name="contact-en"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          novalidate
          class="flex flex-col gap-5"
          aria-label="Contact form"
        >
          <p style="display:none" aria-hidden="true">
            <label>Do not fill: <input name="bot-field" tabindex="-1" /></label>
          </p>
          <input type="hidden" name="form-name" value="contact-en" />

          <div class="flex flex-col gap-1.5">
            <label for="nom-en" class="text-sm font-medium text-navy">
              Full name <span aria-hidden="true" class="text-red-500">*</span>
            </label>
            <input
              type="text" id="nom-en" name="nom" required aria-required="true"
              aria-describedby="nom-en-error" autocomplete="name"
              class="border border-gray-200 rounded px-3 py-2.5 text-sm font-normal text-gray-800 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors"
              placeholder="Your name"
            />
            <span id="nom-en-error" role="alert" class="text-xs text-red-600 hidden" aria-live="polite"></span>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="email-en" class="text-sm font-medium text-navy">
              Email address <span aria-hidden="true" class="text-red-500">*</span>
            </label>
            <input
              type="email" id="email-en" name="email" required aria-required="true"
              aria-describedby="email-en-error" autocomplete="email"
              class="border border-gray-200 rounded px-3 py-2.5 text-sm font-normal text-gray-800 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors"
              placeholder="your@email.com"
            />
            <span id="email-en-error" role="alert" class="text-xs text-red-600 hidden" aria-live="polite"></span>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="message-en" class="text-sm font-medium text-navy">
              Message <span aria-hidden="true" class="text-red-500">*</span>
            </label>
            <textarea
              id="message-en" name="message" required aria-required="true"
              aria-describedby="message-en-error" maxlength="1000" rows={6}
              class="border border-gray-200 rounded px-3 py-2.5 text-sm font-normal text-gray-800 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors resize-y"
              placeholder="Your message..."
            ></textarea>
            <span id="message-en-error" role="alert" class="text-xs text-red-600 hidden" aria-live="polite"></span>
          </div>

          <button
            type="submit"
            class="self-start inline-flex items-center gap-2 bg-navy hover:bg-navy-light text-white text-sm font-medium px-6 py-2.5 rounded transition-colors"
            aria-label="Send the contact form"
          >
            Send message
          </button>
        </form>
      </div>

      <!-- Contact info -->
      <aside class="lg:col-span-2" aria-label="Town hall contact details" data-animate>
        <div class="bg-gray-50 rounded-card p-6 border border-gray-100 sticky top-24">
          <h2 class="text-sm font-medium text-navy mb-5">Contact details</h2>
          <div class="flex flex-col gap-4 text-xs font-light text-gray-700">
            <address class="not-italic leading-relaxed">
              Mairie d'Artassenx<br/>
              Lieu-dit Artassenx<br/>
              40090 Artassenx, France
            </address>
            <a href="tel:+33558000000" class="hover:text-gold transition-colors">+33 5 58 00 00 00</a>
            <a href="mailto:mairie.artassenx@wanadoo.fr" class="hover:text-gold transition-colors break-all">
              mairie.artassenx@wanadoo.fr
            </a>
          </div>
          <div class="mt-5 pt-5 border-t border-gray-200">
            <h3 class="text-xs font-medium text-navy mb-2">Opening hours</h3>
            <p class="text-xs font-light text-gray-600">Monday – Friday<br/>9:00 am – 12:00 pm</p>
          </div>
          <div id="urgences" class="mt-5 pt-5 border-t border-gray-200 scroll-mt-20">
            <h3 class="text-xs font-medium text-navy mb-3">Emergency numbers</h3>
            {[['SAMU (Medical)', '15'], ['Fire brigade', '18'], ['Police', '17'], ['European emergency', '112']].map(([l, n]) => (
              <div class="flex items-center justify-between text-xs mb-1.5">
                <span class="font-light text-gray-600">{l}</span>
                <a href={`tel:${n}`} class="font-semibold text-navy hover:text-gold transition-colors">{n}</a>
              </div>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>
