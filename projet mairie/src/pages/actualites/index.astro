---
import Layout from '../../layouts/Layout.astro';
import ActualiteCard from '../../components/ui/ActualiteCard.astro';
import CategoryFilter from '../../components/ui/CategoryFilter.astro';
import { getCollection } from 'astro:content';

const allActualites = await getCollection('actualites');
const published = allActualites
  .filter((a) => a.data.publie)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
  title="Actualités — Commune d'Artassenx"
  description="Retrouvez toutes les actualités de la commune d'Artassenx : travaux, conseil municipal, événements et informations pratiques."
  canonical="https://artassenx.fr/actualites/"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <!-- En-tête de page -->
    <header class="mb-8" data-animate>
      <nav aria-label="Fil d'Ariane" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-normal text-gray-400">
          <li><a href="/" class="hover:text-gold transition-colors">Accueil</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-gray-600">Actualités</li>
        </ol>
      </nav>
      <h1 class="text-2xl sm:text-3xl font-semibold text-navy mb-2">Actualités</h1>
      <p class="text-sm font-light" style="color: #6B6B68;">
        {published.length} article{published.length > 1 ? 's' : ''} publié{published.length > 1 ? 's' : ''}
      </p>
    </header>

    <!-- Filtres par catégorie -->
    <div class="mb-8" data-animate>
      <CategoryFilter />
    </div>

    <!-- Grille des articles -->
    {published.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="articles-grid">
        {published.map((article) => (
          <ActualiteCard
            title={article.data.title}
            date={article.data.date}
            categorie={article.data.categorie}
            extrait={article.data.extrait}
            slug={article.slug}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
          />
        ))}
      </div>
    ) : (
      <p class="text-sm font-light text-gray-500 py-12 text-center">
        Aucune actualité pour le moment.
      </p>
    )}
  </div>
</Layout>
