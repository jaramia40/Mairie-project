---
import Layout from '../layouts/Layout.astro';
import AssoCard from '../components/ui/AssoCard.astro';
import { getCollection } from 'astro:content';

const allAssos = await getCollection('associations');
const actives = allAssos.filter((a) => a.data.actif);
const inactives = allAssos.filter((a) => !a.data.actif);
---

<Layout
  title="Associations — Commune d'Artassenx"
  description="Annuaire des associations de la commune d'Artassenx : foyer rural, comité des fêtes, anciens combattants et autres."
  canonical="https://artassenx.fr/associations/"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <!-- En-tête -->
    <header class="mb-10" data-animate>
      <nav aria-label="Fil d'Ariane" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-normal text-gray-400">
          <li><a href="/" class="hover:text-gold transition-colors">Accueil</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-gray-600">Associations</li>
        </ol>
      </nav>
      <h1 class="text-3xl font-semibold text-navy mb-2">Associations</h1>
      <p class="text-sm font-light max-w-xl" style="color: #6B6B68;">
        La vie associative est au cœur de la commune. Retrouvez les coordonnées et informations de chaque association locale.
      </p>
    </header>

    <!-- Associations actives -->
    {actives.length > 0 && (
      <section aria-labelledby="actives-heading" class="mb-10">
        <h2 id="actives-heading" class="text-base font-medium text-navy mb-5 pb-2 border-b border-gray-200" data-animate>
          Associations actives ({actives.length})
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {actives.map((asso) => (
            <AssoCard
              nom={asso.data.nom}
              description={asso.data.description}
              contact={asso.data.contact}
              email={asso.data.email}
              actif={asso.data.actif}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Associations inactives -->
    {inactives.length > 0 && (
      <section aria-labelledby="inactives-heading">
        <h2 id="inactives-heading" class="text-base font-medium text-navy mb-5 pb-2 border-b border-gray-200" data-animate>
          Associations inactives ({inactives.length})
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {inactives.map((asso) => (
            <AssoCard
              nom={asso.data.nom}
              description={asso.data.description}
              contact={asso.data.contact}
              email={asso.data.email}
              actif={asso.data.actif}
            />
          ))}
        </div>
      </section>
    )}

    {allAssos.length === 0 && (
      <p class="text-sm font-light text-gray-500 py-12 text-center">
        Aucune association enregistrée pour le moment.
      </p>
    )}

    <!-- Encart "Créer une association" -->
    <div
      class="mt-12 p-6 rounded-card bg-amber-50 border border-amber-100 flex flex-col sm:flex-row items-start sm:items-center gap-4"
      data-animate
    >
      <div class="flex-1">
        <h2 class="text-sm font-medium text-navy mb-1">Vous souhaitez créer une association ?</h2>
        <p class="text-xs font-light text-gray-600 leading-relaxed">
          La mairie peut vous accompagner dans les démarches de création et de déclaration en préfecture.
        </p>
      </div>
      <a
        href="/contact"
        class="flex-shrink-0 text-sm font-medium text-gold border border-gold px-4 py-2 rounded hover:bg-gold hover:text-white transition-colors"
        aria-label="Contacter la mairie pour créer une association"
      >
        Nous contacter
      </a>
    </div>
  </div>
</Layout>
