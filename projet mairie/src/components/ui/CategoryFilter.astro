---
const filters = [
  { key: 'all', label: 'Tout' },
  { key: 'travaux', label: 'Travaux' },
  { key: 'conseil', label: 'Conseil' },
  { key: 'info', label: 'Info' },
  { key: 'evenement', label: 'Événement' },
];
---

<div class="flex flex-wrap gap-2" role="group" aria-label="Filtrer les actualités par catégorie">
  {filters.map(({ key, label }) => (
    <button
      type="button"
      data-filter={key}
      aria-pressed={key === 'all' ? 'true' : 'false'}
      class="filter-btn text-xs font-normal px-3 py-1.5 rounded-full border transition-colors duration-200"
    >
      {label}
    </button>
  ))}
</div>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('[data-categorie]');

  function applyFilter(filter: string) {
    // Mise à jour des boutons
    buttons.forEach((btn) => {
      const isActive = btn.dataset.filter === filter;
      btn.setAttribute('aria-pressed', String(isActive));
      if (isActive) {
        btn.style.backgroundColor = '#1A2D6B';
        btn.style.color = '#FFFFFF';
        btn.style.borderColor = '#1A2D6B';
      } else {
        btn.style.backgroundColor = '#F5F5F3';
        btn.style.color = '#6B6B68';
        btn.style.borderColor = '#E5E7EB';
      }
    });

    // Filtrage des cartes avec animation
    cards.forEach((card) => {
      const cat = card.dataset.categorie;
      if (filter === 'all' || cat === filter) {
        card.style.display = '';
        card.style.opacity = '0';
        requestAnimationFrame(() => {
          card.style.transition = 'opacity 200ms ease';
          card.style.opacity = '1';
        });
      } else {
        card.style.display = 'none';
      }
    });

    // Mise à jour URL sans rechargement
    const url = new URL(window.location.href);
    if (filter === 'all') {
      url.searchParams.delete('categorie');
    } else {
      url.searchParams.set('categorie', filter);
    }
    history.pushState({}, '', url.toString());
  }

  // Restaurer le filtre depuis l'URL
  const params = new URLSearchParams(window.location.search);
  const initial = params.get('categorie') ?? 'all';
  applyFilter(initial);

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      applyFilter(btn.dataset.filter ?? 'all');
    });
  });
</script>
