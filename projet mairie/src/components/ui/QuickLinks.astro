---
interface Props {
  locale?: string;
}
const { locale = 'fr' } = Astro.props;

const links = locale === 'en'
  ? [
      {
        label: 'Online services',
        href: 'https://www.service-public.fr',
        external: true,
        ariaLabel: 'Access online public services (new tab)',
      },
      {
        label: 'Opening hours',
        href: '/en/practical-info#hours',
        external: false,
        ariaLabel: 'See town hall opening hours',
      },
      {
        label: 'Municipal council',
        href: '/conseil-municipal',
        external: false,
        ariaLabel: 'See municipal council minutes',
      },
      {
        label: 'Emergency contacts',
        href: '/en/contact#urgences',
        external: false,
        ariaLabel: 'Emergency and useful contacts',
      },
    ]
  : [
      {
        label: 'Démarches en ligne',
        href: 'https://www.service-public.fr',
        external: true,
        ariaLabel: 'Accéder aux démarches administratives en ligne sur service-public.fr (nouvelle fenêtre)',
      },
      {
        label: 'Horaires mairie',
        href: '/vie-pratique#horaires',
        external: false,
        ariaLabel: 'Consulter les horaires d\'ouverture de la mairie',
      },
      {
        label: 'Conseil municipal',
        href: '/conseil-municipal',
        external: false,
        ariaLabel: 'Accéder aux comptes-rendus du conseil municipal',
      },
      {
        label: 'Urgences & contacts',
        href: '/contact#urgences',
        external: false,
        ariaLabel: 'Contacts d\'urgence et numéros utiles',
      },
    ];

const icons = [
  // Démarches / Online services
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 22 22" fill="none">
    <rect x="3" y="4" width="16" height="14" rx="2" stroke="#1A2D6B" stroke-width="1.4"/>
    <path d="M7 9H15M7 13H11" stroke="#1A2D6B" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M15 11L18 14" stroke="#C47A0A" stroke-width="1.4" stroke-linecap="round"/>
    <circle cx="17" cy="15" r="2.5" stroke="#C47A0A" stroke-width="1.2"/>
  </svg>`,
  // Horaires / Opening hours
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 22 22" fill="none">
    <circle cx="11" cy="11" r="8" stroke="#1A2D6B" stroke-width="1.4"/>
    <path d="M11 7V11L14 13" stroke="#C47A0A" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  // Conseil / Municipal council
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 22 22" fill="none">
    <rect x="3" y="3" width="16" height="16" rx="2" stroke="#1A2D6B" stroke-width="1.4"/>
    <path d="M7 8H15M7 12H13M7 16H11" stroke="#1A2D6B" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M14 14L16 16" stroke="#C47A0A" stroke-width="1.6" stroke-linecap="round"/>
  </svg>`,
  // Urgences / Emergency
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 22 22" fill="none">
    <path d="M11 3L3 19H19L11 3Z" stroke="#1A2D6B" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M11 9V13" stroke="#C47A0A" stroke-width="1.6" stroke-linecap="round"/>
    <circle cx="11" cy="16" r="0.8" fill="#C47A0A"/>
  </svg>`,
];
---

<div
  class="grid grid-cols-2 sm:grid-cols-4 rounded-card overflow-hidden border border-gray-200"
  style="border-radius: 12px;"
  role="list"
  aria-label="Raccourcis rapides"
>
  {links.map((link, i) => (
    <div role="listitem" class={i > 0 ? 'border-l border-gray-200' : ''}>
      <a
        href={link.href}
        target={link.external ? '_blank' : undefined}
        rel={link.external ? 'noopener noreferrer' : undefined}
        aria-label={link.ariaLabel}
        class="flex flex-col items-center justify-center gap-2.5 px-3 py-5 bg-white hover:bg-amber-50 transition-colors group text-center"
      >
        <span class="group-hover:scale-110 transition-transform duration-200">
          <Fragment set:html={icons[i]} />
        </span>
        <span class="text-[11px] font-normal text-gray-700 leading-tight group-hover:text-navy transition-colors">
          {link.label}
        </span>
        {link.external && (
          <svg
            aria-hidden="true"
            width="10"
            height="10"
            viewBox="0 0 10 10"
            fill="none"
            class="text-gray-300 group-hover:text-gold transition-colors"
          >
            <path d="M2 8L8 2M5 2H8V5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        )}
      </a>
    </div>
  ))}
</div>
