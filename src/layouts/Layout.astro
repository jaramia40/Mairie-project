---
import '@fontsource/poppins/300.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';

import SEOHead from '../components/seo/SEOHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import AlertBanner from '../components/layout/AlertBanner.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: string;
  locale?: string;
  jsonLdArticle?: {
    headline: string;
    datePublished: string;
  };
}

const {
  title,
  description = "Site officiel de la commune d'Artassenx — Landes (40090). Retrouvez les actualités, les services et les informations municipales.",
  image,
  canonical,
  type = 'website',
  locale = 'fr',
  jsonLdArticle,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <SEOHead
      title={title}
      description={description}
      image={image}
      canonical={canonical ?? Astro.url.href}
      type={type}
      locale={locale}
      jsonLdArticle={jsonLdArticle}
    />
    <ViewTransitions />
  </head>
  <body class="font-sans bg-white text-gray-900 antialiased flex flex-col min-h-screen">
    <!-- Skip link RGAA -->
    <a href="#main-content" class="skip-link">
      {locale === 'en' ? 'Skip to main content' : 'Aller au contenu principal'}
    </a>

    <AlertBanner locale={locale} />
    <Header locale={locale} currentPath={Astro.url.pathname} />

    <main id="main-content" role="main" tabindex="-1" class="flex-1">
      <slot />
    </main>

    <Footer locale={locale} />

    <script>
      function initAnimations() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate-in');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
      }

      document.addEventListener('astro:page-load', initAnimations);
    </script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.init({
          APIUrl: 'https://artassenx-mairie.netlify.app/.netlify/identity'
        });

        // Ouvre la modale si lien d'invitation ou de récupération
        var hash = window.location.hash;
        if (hash && (hash.includes('invite_token') || hash.includes('recovery_token'))) {
          window.netlifyIdentity.open();
        }

        window.netlifyIdentity.on('init', function(user) {
          if (!user) {
            window.netlifyIdentity.on('login', function() {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  /* CSS Variables */
  :root {
    --color-navy: #1A2D6B;
    --color-navy-light: #2A3D8B;
    --color-navy-dark: #111E4A;
    --color-gold: #C47A0A;
    --color-gold-light: #E8A020;
    --color-gold-dark: #8B5607;
    --color-surface: #F5F5F3;
    --color-text-secondary: #6B6B68;
  }

  /* Reset minimal */
  *, *::before, *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    padding: 0;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  /* Focus visible global RGAA */
  :focus-visible {
    outline: 2px solid #C47A0A;
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Skip link RGAA */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    background: #C47A0A;
    color: #fff;
    padding: 8px 16px;
    border-radius: 0 0 8px 8px;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    z-index: 9999;
    text-decoration: none;
  }
  .skip-link:focus {
    top: 0;
  }

  /* Apparition au scroll */
  [data-animate] {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 400ms ease, transform 400ms ease;
  }
  [data-animate].animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    [data-animate],
    [data-animate].animate-in {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Prose styles for markdown content */
  .prose h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-navy);
    margin: 1.5rem 0 0.75rem;
  }
  .prose h3 {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-navy);
    margin: 1.25rem 0 0.5rem;
  }
  .prose p {
    margin: 0 0 1rem;
    line-height: 1.7;
    font-weight: 300;
  }
  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin: 0.75rem 0 1rem;
    font-weight: 300;
    line-height: 1.7;
  }
  .prose li {
    margin-bottom: 0.35rem;
  }
  .prose strong {
    font-weight: 600;
    color: var(--color-navy);
  }
  .prose a {
    color: var(--color-gold);
    text-decoration: underline;
  }
  .prose a:hover {
    color: var(--color-gold-light);
  }
  .prose blockquote {
    border-left: 4px solid var(--color-gold);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
