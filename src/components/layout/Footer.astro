---
interface Props {
  locale?: string;
}
const { locale = 'fr' } = Astro.props;
const year = new Date().getFullYear();
---

<footer role="contentinfo" class="bg-navy text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">

      <!-- Colonne 1 : Coordonnées -->
      <div>
        <h2 class="text-[10px] font-medium uppercase tracking-widest text-gold mb-4">
          {locale === 'en' ? 'Town hall' : 'Mairie d\'Artassenx'}
        </h2>
        <address class="not-italic font-light text-sm leading-relaxed text-white/80">
          <p>431 route de Bascons</p>
          <p>40090 Artassenx</p>
          <p class="mt-3">
            <a
              href="tel:+33558440399"
              class="hover:text-gold-light transition-colors"
              aria-label="Appeler la mairie au 05 58 44 03 99"
            >
              05 58 44 03 99
            </a>
          </p>
          <p>
            <a
              href="mailto:mairie@artassenx.fr"
              class="hover:text-gold-light transition-colors"
              aria-label="Écrire à la mairie"
            >
              mairie@artassenx.fr
            </a>
          </p>
        </address>
      </div>

      <!-- Colonne 2 : Horaires -->
      <div>
        <h2 class="text-[10px] font-medium uppercase tracking-widest text-gold mb-4">
          {locale === 'en' ? 'Opening hours' : 'Horaires d\'ouverture'}
        </h2>
        <ul class="font-light text-sm leading-relaxed text-white/80 space-y-1.5" role="list">
          <li>
            <span class="font-medium text-white">
              {locale === 'en' ? 'Monday – Wednesday' : 'Lundi – Mercredi'}
            </span>
          </li>
          <li>{locale === 'en' ? '9:00 am – 12:00 pm / 1:00 pm – 5:00 pm' : '9h00 – 12h00 / 13h00 – 17h00'}</li>
          <li>
            <span class="font-medium text-white">
              {locale === 'en' ? 'Thursday' : 'Jeudi'}
            </span>
          </li>
          <li>{locale === 'en' ? 'Closed (public)' : 'Fermé au public'}</li>
          <li>
            <span class="font-medium text-white">
              {locale === 'en' ? 'Friday' : 'Vendredi'}
            </span>
          </li>
          <li>{locale === 'en' ? '9:00 am – 12:00 pm' : '9h00 – 12h00'}</li>
          <li>{locale === 'en' ? 'Closed Saturday and Sunday' : 'Samedi et dimanche fermé'}</li>
        </ul>
      </div>

      <!-- Colonne 3 : Liens légaux -->
      <div>
        <h2 class="text-[10px] font-medium uppercase tracking-widest text-gold mb-4">
          {locale === 'en' ? 'Legal' : 'Informations légales'}
        </h2>
        <ul class="font-light text-sm leading-relaxed space-y-2" role="list">
          <li>
            <a
              href={locale === 'en' ? '/mentions-legales' : '/mentions-legales'}
              class="text-white/70 hover:text-gold-light transition-colors"
            >
              {locale === 'en' ? 'Legal notices' : 'Mentions légales'}
            </a>
          </li>
          <li>
            <a
              href="/accessibilite"
              class="text-white/70 hover:text-gold-light transition-colors"
            >
              {locale === 'en' ? 'Accessibility' : 'Accessibilité'}
            </a>
          </li>
          <li>
            <a
              href={locale === 'en' ? '/en/contact' : '/contact'}
              class="text-white/70 hover:text-gold-light transition-colors"
            >
              {locale === 'en' ? 'Contact' : 'Contact'}
            </a>
          </li>
          <li>
            <a
              href="/admin/"
              class="text-white/70 hover:text-gold-light transition-colors"
              aria-label="Accès espace administration (élus)"
            >
              {locale === 'en' ? 'Admin' : 'Espace élus'}
            </a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Barre de bas de footer -->
  <div class="bg-navy-dark border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-light text-xs text-white/50 text-center sm:text-left">
        © {year} Commune d'Artassenx — {locale === 'en' ? 'All rights reserved' : 'Tous droits réservés'}
      </p>

      <!-- Lien Facebook -->
      <a
        href="https://www.facebook.com/profile.php?id=61551035578584"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Page Facebook de la commune d'Artassenx (nouvelle fenêtre)"
        class="flex items-center gap-2 text-xs font-normal text-white/50 hover:text-white transition-colors group"
      >
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#1877F2] group-hover:scale-110 transition-transform">
          <path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
        </svg>
        {locale === 'en' ? 'Follow us on Facebook' : 'Nous suivre sur Facebook'}
      </a>

      <p class="font-light text-xs text-white/40 text-center">
        Propulsé par <span class="text-gold">Astro</span> + <span class="text-gold">Decap CMS</span>
      </p>
    </div>
  </div>
</footer>
