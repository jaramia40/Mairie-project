---
import Layout from '../../layouts/Layout.astro';
import AssoCard from '../../components/ui/AssoCard.astro';
import { getCollection } from 'astro:content';

const allAssos = await getCollection('associations');
const actives = allAssos.filter((a) => a.data.actif);
---

<Layout
  title="Associations — Artassenx"
  description="Directory of associations in the village of Artassenx: foyer rural, fêtes committee and more."
  canonical="https://artassenx.fr/en/associations/"
  locale="en"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <header class="mb-10" data-animate>
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-normal text-gray-400">
          <li><a href="/en" class="hover:text-gold transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-gray-600">Associations</li>
        </ol>
      </nav>
      <h1 class="text-3xl font-semibold text-navy mb-2">Associations</h1>
      <p class="text-sm font-light max-w-xl" style="color: #6B6B68;">
        Village life in Artassenx revolves around its local associations.
      </p>
    </header>

    {actives.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {actives.map((asso) => (
          <AssoCard
            nom={asso.data.nom}
            description={asso.data.description}
            contact={asso.data.contact}
            email={asso.data.email}
            actif={asso.data.actif}
          />
        ))}
      </div>
    ) : (
      <p class="text-sm font-light text-gray-500 py-12 text-center">No associations registered yet.</p>
    )}
  </div>
</Layout>
