---
import Layout from '../../layouts/Layout.astro';
import ActualiteCard from '../../components/ui/ActualiteCard.astro';
import QuickLinks from '../../components/ui/QuickLinks.astro';
import { getCollection } from 'astro:content';

const allActualites = await getCollection('actualites');
const latest = allActualites
  .filter((a) => a.data.publie)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout
  title="Welcome to Artassenx — Official website"
  description="Official website of Artassenx village (Landes, 40090). News, municipal services, associations and local life."
  canonical="https://artassenx.fr/en/"
  locale="en"
>
  <!-- HERO -->
  <section
    aria-label="Village presentation"
    style="position: sticky; top: 64px; z-index: 0;"
  >
    <img
      src="/images/banniere.jpg"
      alt="Artassenx town hall and village coat of arms"
      class="w-full block"
      style="aspect-ratio: 16/7; min-height: 220px; object-fit: cover; object-position: bottom;"
      loading="eager"
      fetchpriority="high"
      width="1536"
      height="1024"
    />
  </section>

  <div style="position: relative; z-index: 1; background: white;">

    <!-- CTA BANNER -->
    <div style="background: linear-gradient(90deg, #1A2D6B 0%, #111E4A 100%);">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <p class="text-xs font-light tracking-widest uppercase text-gold mb-1 opacity-90">
            285 inhabitants · Landes Department · 40090
          </p>
          <p class="text-sm font-light text-white/75 leading-relaxed max-w-lg">
            Find all municipal information, event calendar and services for our village.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 flex-shrink-0">
          <a
            href="/en/news"
            class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-white text-sm font-medium px-5 py-2.5 rounded transition-colors"
            aria-label="View all village news"
          >
            Our news
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="/en/contact"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white text-sm font-normal px-5 py-2.5 rounded border border-white/20 transition-colors"
            aria-label="Contact Artassenx town hall"
          >
            Contact us
          </a>
        </div>
      </div>
    </div>

  <!-- QUICK LINKS -->
  <section class="bg-white border-b border-gray-100" aria-labelledby="quicklinks-en-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <h2 id="quicklinks-en-heading" class="sr-only">Quick links</h2>
      <QuickLinks locale="en" />
    </div>
  </section>

  <!-- LATEST NEWS -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14" aria-labelledby="news-en-heading">
    <div class="flex items-center justify-between mb-8" data-animate>
      <div>
        <h2 id="news-en-heading" class="text-2xl font-semibold text-navy">Latest news</h2>
        <p class="text-sm font-light mt-1" style="color: #6B6B68;">Information and events from our village</p>
      </div>
    </div>
    {latest.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latest.map((article) => (
          <ActualiteCard
            title={article.data.title}
            date={article.data.date}
            categorie={article.data.categorie}
            extrait={article.data.extrait}
            slug={article.slug}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
          />
        ))}
      </div>
    ) : (
      <p class="text-sm font-light text-gray-500">No news available at the moment.</p>
    )}
  </section>

  <!-- VILLAGE INFO -->
  <section class="py-12 px-4 sm:px-6" style="background-color: #F5F5F3;" aria-labelledby="info-en-heading">
    <div class="max-w-6xl mx-auto">
      <h2 id="info-en-heading" class="text-xl font-semibold text-navy mb-6" data-animate>About Artassenx</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        <div class="bg-white rounded-card p-5 border border-gray-100" data-animate>
          <h3 class="text-sm font-medium text-navy mb-2">Town hall</h3>
          <p class="text-xs font-light text-gray-600 leading-relaxed">
            431 route de Bascons<br/>40090 Artassenx<br/>Tel. 05 58 44 03 99
          </p>
        </div>
        <div class="bg-white rounded-card p-5 border border-gray-100" data-animate>
          <h3 class="text-sm font-medium text-navy mb-2">Opening hours</h3>
          <p class="text-xs font-light text-gray-600 leading-relaxed">
            Mon – Wed: 9:00 am – 12:00 pm / 1:00 pm – 5:00 pm<br/>
            Thursday: closed (public)<br/>
            Friday: 9:00 am – 12:00 pm
          </p>
        </div>
        <div class="bg-white rounded-card p-5 border border-gray-100" data-animate>
          <h3 class="text-sm font-medium text-navy mb-2">Population</h3>
          <p class="text-xs font-light text-gray-600 leading-relaxed">
            285 inhabitants<br/>Arrondissement of Mont-de-Marsan<br/>Landes department
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FACEBOOK -->
  <section class="px-4 sm:px-6 py-10 border-t border-gray-100" aria-labelledby="facebook-en-heading" data-animate>
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col sm:flex-row items-center gap-6 bg-white rounded-card border border-gray-100 p-6 sm:p-8 shadow-sm">
        <div class="flex items-center gap-4 flex-shrink-0">
          <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0" style="background:#1877F2;">
            <svg aria-hidden="true" width="28" height="28" viewBox="0 0 24 24" fill="white">
              <path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-medium uppercase tracking-widest text-gray-400 mb-0.5">Facebook</p>
            <p class="text-sm font-medium text-navy">Commune d'Artassenx</p>
          </div>
        </div>
        <div class="flex-1 text-center sm:text-left">
          <h2 id="facebook-en-heading" class="text-base font-medium text-navy mb-1">Follow us on Facebook</h2>
          <p class="text-xs font-light leading-relaxed" style="color:#6B6B68;">
            Latest news, event photos and last-minute information directly on our page.
          </p>
        </div>
        <a
          href="https://www.facebook.com/profile.php?id=61551035578584"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit Artassenx Facebook page (new tab)"
          class="flex-shrink-0 inline-flex items-center gap-2 text-sm font-medium text-white px-5 py-2.5 rounded transition-colors"
          style="background:#1877F2;"
          onmouseover="this.style.background='#1464D8'"
          onmouseout="this.style.background='#1877F2'"
        >
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
          </svg>
          Visit our page
        </a>
      </div>
    </div>
  </section>

  </div><!-- end scrollable content -->
</Layout>
