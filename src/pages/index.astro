---
import Layout from '../layouts/Layout.astro';
import ActualiteCard from '../components/ui/ActualiteCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
type Actu = CollectionEntry<'actualites'>;

const allActualites = await getCollection('actualites');
const latest = allActualites
  .filter((a: Actu) => a.data.publie)
  .sort((a: Actu, b: Actu) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allAgenda = await getCollection('agenda');
const now = new Date();
now.setHours(0, 0, 0, 0);
const prochains = allAgenda
  .filter((e) => e.data.publie && e.data.date >= now)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
  .slice(0, 3);
---

<Layout
  title="Accueil — Commune d'Artassenx"
  description="Site officiel de la commune d'Artassenx (Landes, 40090). Actualités, services municipaux, associations et vie locale."
  canonical="https://artassenx.fr/"
>
  <!-- ===== HERO : BANNIÈRE STICKY ===== -->
  <!--
    La section est sticky (z-0) : elle reste collée sous le header pendant que
    le bloc .page-content (z-1, fond blanc) glisse par-dessus au scroll.
  -->
  <section
    aria-label="Présentation de la commune"
    style="position: sticky; top: 96px; z-index: 0;"
  >
    <!-- Seule l'image est sticky — ratio 16/7, pleine largeur, sans déformation -->
    <img
      src="/images/banniere.jpg"
      alt="La mairie d'Artassenx et le blason de la commune"
      class="w-full block"
      style="aspect-ratio: 16/7; min-height: 220px; object-fit: cover; object-position: bottom;"
      loading="eager"
      fetchpriority="high"
      width="1536"
      height="1024"
    />
  </section>

  <!-- ===== CONTENU QUI GLISSE PAR-DESSUS LA BANNIÈRE ===== -->
  <div style="position: relative; z-index: 1; background: white;">

    <!-- Bandeau CTA navy : premier élément à monter sur la bannière -->
    <div style="background: linear-gradient(90deg, #1A2D6B 0%, #111E4A 100%);">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5 sm:py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 sm:gap-4">
        <div>
          <p class="text-xs font-light tracking-widest uppercase text-gold mb-1 opacity-90">
            285 habitants · Département des Landes · 40090
          </p>
          <p class="text-sm font-light text-white/75 leading-relaxed max-w-lg">
            Retrouvez toutes les informations municipales, l'agenda des événements et les services de votre commune.
          </p>
        </div>
        <div class="flex flex-wrap gap-2 sm:gap-3 flex-shrink-0 w-full sm:w-auto">
          <a
            href="/vie-locale"
            class="flex-1 sm:flex-none justify-center inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-white text-sm font-medium px-5 py-2.5 rounded transition-colors"
            aria-label="Voir toutes les actualités de la commune"
          >
            Nos actualités
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="/contact"
            class="flex-1 sm:flex-none justify-center inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white text-sm font-normal px-5 py-2.5 rounded border border-white/20 transition-colors"
            aria-label="Contacter la mairie d'Artassenx"
          >
            Contacter la mairie
          </a>
        </div>
      </div>
    </div>

  <!-- ===== NOUVEAUX HABITANTS ===== -->
  <section class="bg-white border-b border-gray-100" aria-labelledby="nouveaux-heading" data-animate>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <div class="p-5 bg-amber-50 border border-amber-100 rounded-xl">
        <h2 id="nouveaux-heading" class="text-base font-semibold text-navy mb-1 text-center">Vous venez d'arriver à Artassenx ?</h2>
        <p class="text-sm font-light text-gray-600 mb-4 text-center">Bienvenue dans la commune. Retrouvez les informations utiles pour bien vous installer.</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          <a href="/vie-pratique" class="flex flex-col items-center gap-1.5 p-3 bg-white rounded-lg border border-amber-100 hover:border-gold/40 transition-colors group no-underline">
            <svg class="text-gold" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.4a16 16 0 0 0 7.69 7.69l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span class="text-sm font-medium text-navy group-hover:text-gold transition-colors text-center">Contacter la mairie</span>
          </a>
          <a href="/vie-pratique#demarches" data-astro-reload class="flex flex-col items-center gap-1.5 p-3 bg-white rounded-lg border border-amber-100 hover:border-gold/40 transition-colors group no-underline">
            <svg class="text-gold" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            <span class="text-sm font-medium text-navy group-hover:text-gold transition-colors text-center">Premières démarches</span>
          </a>
          <a href="/vie-pratique#enfance" data-astro-reload class="flex flex-col items-center gap-1.5 p-3 bg-white rounded-lg border border-amber-100 hover:border-gold/40 transition-colors group no-underline">
            <svg class="text-gold" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            <span class="text-sm font-medium text-navy group-hover:text-gold transition-colors text-center">Enfance & École</span>
          </a>
          <a href="/vie-locale" class="flex flex-col items-center gap-1.5 p-3 bg-white rounded-lg border border-amber-100 hover:border-gold/40 transition-colors group no-underline">
            <svg class="text-gold" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg>
            <span class="text-sm font-medium text-navy group-hover:text-gold transition-colors text-center">Vie locale</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCHAINS ÉVÉNEMENTS ===== -->
  {prochains.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14 border-t border-gray-100" aria-labelledby="agenda-heading" data-animate>
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 id="agenda-heading" class="text-2xl font-semibold text-navy">Prochains événements</h2>
          <p class="text-sm font-light mt-1" style="color:#6B6B68;">À venir dans la commune</p>
        </div>
        <a href="/vie-locale" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-gold hover:text-gold-light transition-colors" aria-label="Voir tout l'agenda">
          Tout l'agenda
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {prochains.map((e) => {
          const jour = e.data.date.toLocaleDateString('fr-FR', { day: 'numeric' });
          const mois = e.data.date.toLocaleDateString('fr-FR', { month: 'short' }).replace('.', '');
          const annee = e.data.date.getFullYear();
          return (
            <div class="group bg-white rounded-xl border border-gray-100 overflow-hidden transition-all duration-200 hover:-translate-y-1 hover:shadow-lg">
              <div class="h-36 overflow-hidden flex-shrink-0" style="background:#F5F5F3;">
                {e.data.image ? (
                  <img src={e.data.image} alt={e.data.titre} class="w-full h-full object-cover" loading="lazy" decoding="async" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <div class="flex flex-col items-center justify-center bg-navy text-white rounded-xl w-16 h-16">
                      <span class="text-xl font-semibold leading-none">{jour}</span>
                      <span class="text-[10px] font-medium uppercase tracking-wide text-gold mt-0.5">{mois}</span>
                    </div>
                  </div>
                )}
              </div>
              <div class="p-4 flex flex-col gap-2">
                <div class="flex items-center justify-between gap-2">
                  <span class="inline-flex items-center gap-1 text-[10px] font-medium px-2 py-0.5 rounded bg-navy/10 text-navy">
                    <svg aria-hidden="true" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                    {jour} {mois}. {annee}
                  </span>
                  <span class="text-[11px] font-light flex-shrink-0" style="color:#6B6B68;">{e.data.heure}</span>
                </div>
                <h3 class="text-sm font-medium text-navy leading-snug line-clamp-2 group-hover:text-gold transition-colors">{e.data.titre}</h3>
                <p class="text-[12px] font-light leading-relaxed line-clamp-2" style="color:#6B6B68;">{e.data.lieu}</p>
                <div class="mt-auto pt-2 flex items-center gap-1 text-[11px] font-medium text-gold">
                  <span>Voir l'événement</span>
                  <svg aria-hidden="true" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              </div>
            </div>
          );
        })}
      </div>
      <div class="mt-4 sm:hidden text-center">
        <a href="/vie-locale" class="inline-flex items-center gap-2 text-sm font-medium text-gold hover:text-gold-light transition-colors">
          Voir tout l'agenda
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>
  )}

  <!-- ===== SALLE DES FÊTES ===== -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10 border-t border-gray-100" aria-labelledby="salle-heading" data-animate>
    <div class="flex flex-col sm:flex-row rounded-xl overflow-hidden border border-amber-100">
      <div class="sm:w-2/5 h-52 sm:h-auto overflow-hidden flex-shrink-0">
        <img src="/images/banniere.jpg" alt="Salle des fêtes d'Artassenx" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="flex-1 p-6 sm:p-8 flex flex-col justify-center gap-4 bg-amber-50">
        <div>
          <h2 id="salle-heading" class="text-xl font-semibold text-navy mb-3">Un lieu pour organiser vos événements ?</h2>
          <p class="text-sm font-light text-gray-600 leading-relaxed mb-2">
            La salle des fêtes d'Artassenx accueille repas, réunions, fêtes familiales, animations associatives et manifestations communales.
          </p>
          <p class="text-sm font-light text-gray-600 leading-relaxed">
            Retrouvez les informations utiles pour préparer votre demande de location : présentation, tarifs, documents et contact mairie.
          </p>
        </div>
        <a
          href="/salle-des-fetes"
          class="self-start inline-flex items-center gap-2 bg-navy hover:bg-navy-dark text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors"
        >
          Découvrir la salle des fêtes
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== DERNIÈRES ACTUALITÉS ===== -->
  <section
    class="max-w-6xl mx-auto px-4 sm:px-6 py-14"
    aria-labelledby="news-heading"
  >
    <div class="flex items-center justify-between mb-8" data-animate>
      <div>
        <h2 id="news-heading" class="text-2xl font-semibold text-navy">
          Dernières actualités
        </h2>
        <p class="text-sm font-light mt-1" style="color: #6B6B68;">
          Informations et événements de votre commune
        </p>
      </div>
      <a
        href="/vie-locale"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-gold hover:text-gold-light transition-colors"
        aria-label="Voir toutes les actualités"
      >
        Tout voir
        <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    {latest.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latest.map((article: CollectionEntry<'actualites'>) => (
          <ActualiteCard
            title={article.data.title}
            date={article.data.date}
            categorie={article.data.categorie}
            extrait={article.data.extrait}
            slug={article.slug}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
          />
        ))}
      </div>
    ) : (
      <p class="text-sm font-light text-gray-500">Aucune actualité pour le moment.</p>
    )}

    <div class="mt-8 sm:hidden text-center">
      <a
        href="/vie-locale"
        class="inline-flex items-center gap-2 text-sm font-medium text-gold hover:text-gold-light transition-colors"
        aria-label="Voir toutes les actualités"
      >
        Voir toutes les actualités
        <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ===== FACEBOOK ===== -->
  <section
    class="px-4 sm:px-6 py-10 border-t border-gray-100"
    aria-labelledby="facebook-heading"
    data-animate
  >
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col sm:flex-row items-center gap-6 bg-amber-50 rounded-xl border border-amber-100 p-6 sm:p-8">

        <!-- Icône + identité -->
        <div class="flex items-center gap-4 flex-shrink-0">
          <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0" style="background:#1877F2;">
            <svg aria-hidden="true" width="28" height="28" viewBox="0 0 24 24" fill="white">
              <path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-medium uppercase tracking-widest text-gray-400 mb-0.5">Facebook</p>
            <p class="text-sm font-medium text-navy">Commune d'Artassenx</p>
          </div>
        </div>

        <!-- Texte -->
        <div class="flex-1 text-center sm:text-left">
          <h2 id="facebook-heading" class="text-base font-medium text-navy mb-1">
            Suivez-nous sur Facebook
          </h2>
          <p class="text-xs font-light leading-relaxed" style="color:#6B6B68;">
            Actualités en temps réel, photos des événements et informations de dernière minute directement sur notre page.
          </p>
        </div>

        <!-- CTA -->
        <a
          href="https://www.facebook.com/profile.php?id=61551035578584"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Voir la page Facebook de la commune d'Artassenx (nouvelle fenêtre)"
          class="flex-shrink-0 inline-flex items-center gap-2 text-sm font-medium text-white px-5 py-2.5 rounded transition-colors"
          style="background:#1877F2;"
          onmouseover="this.style.background='#1464D8'"
          onmouseout="this.style.background='#1877F2'"
        >
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
          </svg>
          Voir notre page
        </a>
      </div>
    </div>
  </section>

  <!-- ===== INFOS PRATIQUES RAPIDES ===== -->
  <section
    class="py-12 px-4 sm:px-6"
    style="background-color: #F5F5F3;"
    aria-labelledby="infos-heading"
  >
    <div class="max-w-6xl mx-auto">
      <h2 id="infos-heading" class="text-xl font-semibold text-navy mb-6" data-animate>
        La commune en bref
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-5">

        <!-- Mairie -->
        <div class="bg-white rounded-card p-5 border border-gray-100" data-animate>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center flex-shrink-0">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="2" y="7" width="14" height="9" rx="1.5" stroke="#1A2D6B" stroke-width="1.3"/>
                <path d="M1 7L9 2L17 7" stroke="#1A2D6B" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="7" y="11" width="4" height="5" rx="0.5" stroke="#C47A0A" stroke-width="1.2"/>
              </svg>
            </div>
            <h3 class="text-sm font-medium text-navy">Mairie</h3>
          </div>
          <p class="text-xs font-light text-gray-600 leading-relaxed">
            431 route de Bascons<br />
            40090 Artassenx<br />
            Tél. 05 58 44 03 99
          </p>
        </div>

        <!-- Horaires -->
        <div class="bg-white rounded-card p-5 border border-gray-100" data-animate>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center flex-shrink-0">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="7" stroke="#C47A0A" stroke-width="1.3"/>
                <path d="M9 5V9L12 11" stroke="#C47A0A" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="text-sm font-medium text-navy">Horaires</h3>
          </div>
          <p class="text-xs font-light text-gray-600 leading-relaxed">
            Lun – Mer : 9h–12h / 13h–17h<br />
            Jeudi : fermé au public<br />
            Vendredi : 9h–12h<br />
            <a href="/vie-pratique#horaires" class="text-gold hover:underline">Horaires détaillés →</a>
          </p>
        </div>

        <!-- Population -->
        <div class="bg-white rounded-card p-5 border border-gray-100" data-animate>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-emerald-50 flex items-center justify-center flex-shrink-0">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="7" cy="6" r="3" stroke="#065F46" stroke-width="1.3"/>
                <path d="M2 16c0-3 2.2-5 5-5s5 2 5 5" stroke="#065F46" stroke-width="1.3" stroke-linecap="round"/>
                <circle cx="13" cy="7" r="2" stroke="#065F46" stroke-width="1.2"/>
                <path d="M13 12c1.5 0 3 1 3 4" stroke="#065F46" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="text-sm font-medium text-navy">Population</h3>
          </div>
          <p class="text-xs font-light text-gray-600 leading-relaxed">
            285 habitants<br />
            Arrondissement de Mont-de-Marsan<br />
            Canton de Grenade-sur-l'Adour
          </p>
        </div>

      </div>

      <!-- Carte -->
      <div class="relative rounded-card overflow-hidden border border-gray-100 shadow-sm" data-animate style="height: 260px;">
        <iframe
          title="Localisation de la mairie d'Artassenx"
          src="https://www.openstreetmap.org/export/embed.html?bbox=-0.4190%2C43.8328%2C-0.3790%2C43.8528&layer=mapnik&marker=43.842826%2C-0.399048"
          width="100%"
          height="260"
          style="border:0; display:block;"
          loading="lazy"
          referrerpolicy="no-referrer"
        ></iframe>
        <div class="map-shield absolute inset-0 z-10 cursor-pointer flex items-end justify-center pb-3">
          <span class="text-[11px] bg-white/90 text-gray-500 px-2.5 py-1 rounded-full shadow-sm">Cliquer pour interagir avec la carte</span>
        </div>
      </div>
      <a
        href="https://www.openstreetmap.org/?mlat=43.842826&mlon=-0.399048#map=16/43.842826/-0.399048"
        target="_blank"
        rel="noopener noreferrer"
        class="block mt-1.5 text-[10px] font-light text-gray-400 hover:text-gold transition-colors text-right"
        aria-label="Voir sur OpenStreetMap (nouvelle fenêtre)"
      >
        Voir sur OpenStreetMap ↗
      </a>
    </div>
  </section>

  </div><!-- fin .page-content -->
</Layout>
